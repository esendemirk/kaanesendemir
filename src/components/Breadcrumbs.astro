---
export interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol>
    {
      items.map((item, i) => {
        const last = i === items.length - 1;
        return (
          <li>
            {last || !item.href ? (
              <span aria-current={last ? "page" : undefined}>{item.label}</span>
            ) : (
              <a href={item.href}>{item.label}</a>
            )}
            {!last && <span class="sep" aria-hidden="true">/</span>}
          </li>
        );
      })
    }
  </ol>
</nav>

<style>
  .breadcrumbs {
    margin: 0 0 1rem;
  }
  .breadcrumbs ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.88rem;
    color: var(--muted);
  }
  .breadcrumbs li {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .breadcrumbs a {
    color: var(--muted);
  }
  .breadcrumbs a:hover {
    color: var(--accent);
  }
  .breadcrumbs [aria-current="page"] {
    color: var(--text);
    font-weight: 500;
  }
  .sep {
    color: var(--line);
    user-select: none;
  }
</style>
