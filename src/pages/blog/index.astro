---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getCollection } from "astro:content";
import { SITE_URL, LINKEDIN } from "../../config";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: `${SITE_URL}/`,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Blog",
      item: `${SITE_URL}/blog/`,
    },
  ],
};
---

<BaseLayout
  title="Blog — Kaan Esendemir"
  description="Notes from Application Architect and Adjunct Professor Kaan Esendemir on systems, AI adoption, teaching, and building in public."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <main id="main" class="section">
    <div class="wrap">
      <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Blog" }]} />
      <h1>Blog</h1>
      <p class="muted intro">
        Short writing with clean links for LinkedIn. Prefer a conversation?{" "}
        <a class="inline-link" href={LINKEDIN} target="_blank" rel="noopener noreferrer">LinkedIn</a>.
      </p>
      <div class="card-grid">
        {
          posts.map((p) => (
            <BlogCard
              title={p.data.title}
              summary={p.data.summary}
              href={`/blog/${p.id}/`}
              cover={p.data.cover}
              date={p.data.date}
              tags={p.data.tags}
            />
          ))
        }
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  h1 {
    margin: 0 0 0.75rem;
    font-size: clamp(2rem, 4vw, 2.75rem);
    letter-spacing: -0.03em;
  }
  .intro {
    margin: 0 0 1.75rem;
    max-width: 48ch;
  }
  .inline-link {
    color: var(--accent);
    font-weight: 600;
  }
  .card-grid {
    display: grid;
    gap: 1rem;
  }
  @media (min-width: 800px) {
    .card-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
