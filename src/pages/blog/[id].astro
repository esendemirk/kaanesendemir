---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ShareBar from "../../components/ShareBar.astro";
import { getCollection, render } from "astro:content";
import { SITE_URL, LINKEDIN } from "../../config";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const pageUrl = `${SITE_URL}/blog/${post.id}/`;
const cover = post.data.cover
  ? post.data.cover.startsWith("http")
    ? post.data.cover
    : `${SITE_URL}${post.data.cover}`
  : `${SITE_URL}/images/headshot.png`;

const dateLabel = post.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.summary,
  url: pageUrl,
  image: cover,
  datePublished: post.data.date.toISOString(),
  author: {
    "@type": "Person",
    name: "Kaan Esendemir",
    url: SITE_URL,
    sameAs: [LINKEDIN],
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": pageUrl,
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: `${SITE_URL}/`,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Blog",
      item: `${SITE_URL}/blog/`,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: post.data.title,
      item: pageUrl,
    },
  ],
};
---

<BaseLayout
  title={`${post.data.title} — Kaan Esendemir`}
  description={post.data.summary}
  image={cover}
  type="article"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <main id="main" class="section">
    <article class="wrap article">
      <Breadcrumbs
        items={[
          { label: "Home", href: "/" },
          { label: "Blog", href: "/blog/" },
          { label: post.data.title },
        ]}
      />
      <time class="date" datetime={post.data.date.toISOString()}>{dateLabel}</time>
      <h1>{post.data.title}</h1>
      <p class="summary">{post.data.summary}</p>
      {
        post.data.tags.length > 0 && (
          <ul class="tags">
            {post.data.tags.map((t) => (
              <li>{t}</li>
            ))}
          </ul>
        )
      }
      {
        post.data.cover && (
          <img
            class="cover"
            src={post.data.cover}
            alt=""
            width="1200"
            height="630"
          />
        )
      }
      <div class="body">
        <Content />
      </div>
      <ShareBar url={pageUrl} title={post.data.title} />
    </article>
  </main>
</BaseLayout>

<style>
  .article {
    max-width: 720px;
  }
  .date {
    display: block;
    margin: 0 0 0.5rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
  }
  h1 {
    margin: 0 0 0.75rem;
    font-size: clamp(2rem, 4.5vw, 2.8rem);
    letter-spacing: -0.03em;
    line-height: 1.1;
  }
  .summary {
    margin: 0 0 1rem;
    font-size: 1.1rem;
    color: var(--muted);
    line-height: 1.5;
  }
  .tags {
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tags li {
    font-size: 0.75rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.2rem 0.65rem;
    color: var(--muted);
  }
  .cover {
    width: 100%;
    border-radius: 10px;
    border: 1px solid var(--line);
    margin-bottom: 1.5rem;
  }
  .body :global(p) {
    margin: 0 0 1rem;
    color: var(--muted);
    line-height: 1.7;
  }
  .body :global(strong) {
    color: var(--text);
  }
  .body :global(ul) {
    color: var(--muted);
    line-height: 1.65;
    margin: 0 0 1rem;
    padding-left: 1.2rem;
  }
  .body :global(li) {
    margin: 0 0 0.35rem;
  }
</style>
