---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getCollection } from "astro:content";
import { LINKEDIN } from "../../config";

const projects = (await getCollection("projects")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout
  title="Projects — Kaan Esendemir"
  description="Experiments, AI demos, hardware builds, and long-form work by Application Architect and Adjunct Professor Kaan Esendemir."
>
  <main id="main" class="section">
    <div class="wrap">
      <p class="eyebrow"><a class="back" href="/">← Home</a></p>
      <h1>Projects</h1>
      <p class="muted intro">
        Shareable builds and experiments — enterprise AI, education demos, and edge hardware.
        Prefer a conversation?{" "}
        <a class="inline-link" href={LINKEDIN} target="_blank" rel="noopener noreferrer">LinkedIn</a>.
      </p>
      <div class="card-grid">
        {
          projects.map((p) => (
            <ProjectCard
              title={p.data.title}
              summary={p.data.summary}
              href={`/projects/${p.id}/`}
              cover={p.data.cover}
              status={p.data.status}
              tags={p.data.tags}
            />
          ))
        }
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  h1 {
    margin: 0 0 0.75rem;
    font-size: clamp(2rem, 4vw, 2.75rem);
    letter-spacing: -0.03em;
  }
  .intro {
    margin: 0 0 1.75rem;
    max-width: 48ch;
  }
  .back {
    color: var(--muted);
  }
  .inline-link {
    color: var(--accent);
    font-weight: 600;
  }
  .card-grid {
    display: grid;
    gap: 1rem;
  }
  @media (min-width: 800px) {
    .card-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
