---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ShareBar from "../../components/ShareBar.astro";
import { getCollection, render } from "astro:content";
import { SITE_URL, LINKEDIN } from "../../config";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const pageUrl = `${SITE_URL}/projects/${project.id}/`;
const cover = project.data.cover
  ? project.data.cover.startsWith("http")
    ? project.data.cover
    : `${SITE_URL}${project.data.cover}`
  : `${SITE_URL}/images/headshot.png`;

const workSchema = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: project.data.title,
  description: project.data.summary,
  url: pageUrl,
  image: cover,
  datePublished: project.data.date.toISOString(),
  author: {
    "@type": "Person",
    name: "Kaan Esendemir",
    url: SITE_URL,
    sameAs: [LINKEDIN],
  },
};
---

<BaseLayout
  title={`${project.data.title} — Kaan Esendemir`}
  description={project.data.summary}
  image={cover}
  type="article"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(workSchema)} />

  <main id="main" class="section">
    <article class="wrap article">
      <p class="eyebrow"><a class="back" href="/projects/">← Projects</a></p>
      <p class="status">{project.data.status}</p>
      <h1>{project.data.title}</h1>
      <p class="summary">{project.data.summary}</p>
      {
        project.data.tags.length > 0 && (
          <ul class="tags">
            {project.data.tags.map((t) => (
              <li>{t}</li>
            ))}
          </ul>
        )
      }
      {
        project.data.cover && (
          <img
            class="cover"
            src={project.data.cover}
            alt=""
            width="1200"
            height="630"
          />
        )
      }
      <div class="body">
        <Content />
      </div>
      <ShareBar url={pageUrl} title={project.data.title} />
    </article>
  </main>
</BaseLayout>

<style>
  .article {
    max-width: 720px;
  }
  .back {
    color: var(--muted);
  }
  .status {
    margin: 0.75rem 0 0.35rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }
  h1 {
    margin: 0 0 0.75rem;
    font-size: clamp(2rem, 4.5vw, 2.8rem);
    letter-spacing: -0.03em;
    line-height: 1.1;
  }
  .summary {
    margin: 0 0 1rem;
    font-size: 1.1rem;
    color: var(--muted);
    line-height: 1.5;
  }
  .tags {
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tags li {
    font-size: 0.75rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.2rem 0.65rem;
    color: var(--muted);
  }
  .cover {
    width: 100%;
    border-radius: 10px;
    border: 1px solid var(--line);
    margin-bottom: 1.5rem;
  }
  .body :global(p) {
    margin: 0 0 1rem;
    color: var(--muted);
    line-height: 1.65;
  }
  .body :global(strong) {
    color: var(--text);
  }
  .body :global(ul) {
    color: var(--muted);
  }
</style>
