---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { LINKEDIN } from "../../config";

const chapters = (await getCollection("vision")).sort(
  (a, b) => a.data.order - b.data.order
);

const rendered = await Promise.all(
  chapters.map(async (chapter) => {
    const { Content } = await render(chapter);
    return { chapter, Content };
  })
);
---

<BaseLayout
  title="Vision board — Kaan Esendemir"
  description="A running page on how Kaan Esendemir would lead: non-negotiables, time boundaries, vacation, and team life."
  noindex={true}
>
  <main id="main" class="section">
    <article class="wrap vision">
      <p class="eyebrow"><a class="back" href="/">← Home</a></p>
      <h1>Vision board</h1>
      <p class="lede">
        How I’d run a company — leadership principles as a living note, not a policy PDF. A running
        page I can keep writing into over time.
      </p>
      <p class="muted note">
        Personal / private surface — not indexed. Prefer a conversation?{" "}
        <a class="inline-link" href={LINKEDIN} target="_blank" rel="noopener noreferrer">LinkedIn</a>.
      </p>

      <nav class="toc" aria-label="Chapters">
        <p class="toc-label">On this page</p>
        <ol>
          {
            chapters.map((c) => (
              <li>
                <a href={`#${c.id}`}>{c.data.title}</a>
              </li>
            ))
          }
        </ol>
      </nav>

      {
        rendered.map(({ chapter, Content }) => (
          <section class="chapter" id={chapter.id} aria-labelledby={`${chapter.id}-title`}>
            <h2 id={`${chapter.id}-title`}>
              <a class="chapter-anchor" href={`/vision/${chapter.id}/`}>
                {chapter.data.title}
              </a>
            </h2>
            <p class="chapter-summary">{chapter.data.summary}</p>
            <div class="body">
              <Content />
            </div>
          </section>
        ))
      }
    </article>
  </main>
</BaseLayout>

<style>
  .vision {
    max-width: 720px;
  }
  .back {
    color: var(--muted);
  }
  h1 {
    margin: 0 0 0.75rem;
    font-size: clamp(2rem, 4.5vw, 2.8rem);
    letter-spacing: -0.03em;
    line-height: 1.1;
  }
  .lede {
    margin: 0 0 0.75rem;
    font-size: 1.1rem;
    color: var(--muted);
    line-height: 1.55;
  }
  .note {
    margin: 0 0 1.75rem;
    font-size: 0.95rem;
  }
  .inline-link {
    color: var(--accent);
    font-weight: 600;
  }
  .toc {
    margin: 0 0 2.5rem;
    padding: 1rem 1.15rem;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--surface);
  }
  .toc-label {
    margin: 0 0 0.5rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .toc ol {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--muted);
  }
  .toc a {
    color: var(--text);
  }
  .toc a:hover {
    color: var(--accent);
  }
  .chapter {
    margin: 0 0 2.75rem;
    padding-top: 0.25rem;
    scroll-margin-top: 1.5rem;
  }
  .chapter + .chapter {
    border-top: 1px solid var(--line);
    padding-top: 2.25rem;
  }
  .chapter h2 {
    margin: 0 0 0.4rem;
    font-size: clamp(1.35rem, 2.5vw, 1.65rem);
    letter-spacing: -0.02em;
  }
  .chapter-anchor {
    color: inherit;
  }
  .chapter-anchor:hover {
    color: var(--accent);
  }
  .chapter-summary {
    margin: 0 0 1rem;
    font-size: 0.95rem;
    color: var(--muted);
    font-style: italic;
  }
  .body :global(p) {
    margin: 0 0 1rem;
    color: var(--muted);
    line-height: 1.7;
  }
  .body :global(strong) {
    color: var(--text);
    font-weight: 600;
  }
  .body :global(ul) {
    color: var(--muted);
    line-height: 1.65;
  }
</style>
