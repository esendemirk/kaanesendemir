---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const chapters = await getCollection("vision");
  return chapters.map((chapter) => ({
    params: { id: chapter.id },
    props: { chapter },
  }));
}

const { chapter } = Astro.props;
const { Content } = await render(chapter);
const all = (await getCollection("vision")).sort((a, b) => a.data.order - b.data.order);
const idx = all.findIndex((c) => c.id === chapter.id);
const prev = idx > 0 ? all[idx - 1] : null;
const next = idx < all.length - 1 ? all[idx + 1] : null;
---

<BaseLayout
  title={`${chapter.data.title} — Vision board — Kaan Esendemir`}
  description={chapter.data.summary}
  noindex={true}
>
  <main id="main" class="section">
    <article class="wrap chapter-page">
      <p class="eyebrow"><a class="back" href="/vision/">← Vision board</a></p>
      <h1>{chapter.data.title}</h1>
      <p class="summary">{chapter.data.summary}</p>
      <div class="body">
        <Content />
      </div>
      <nav class="pager" aria-label="Chapter">
        {
          prev ? (
            <a class="pager-link" href={`/vision/${prev.id}/`}>
              ← {prev.data.title}
            </a>
          ) : (
            <span />
          )
        }
        {
          next ? (
            <a class="pager-link next" href={`/vision/${next.id}/`}>
              {next.data.title} →
            </a>
          ) : (
            <span />
          )
        }
      </nav>
    </article>
  </main>
</BaseLayout>

<style>
  .chapter-page {
    max-width: 720px;
  }
  .back {
    color: var(--muted);
  }
  h1 {
    margin: 0 0 0.75rem;
    font-size: clamp(2rem, 4.5vw, 2.8rem);
    letter-spacing: -0.03em;
    line-height: 1.1;
  }
  .summary {
    margin: 0 0 1.5rem;
    font-size: 1.05rem;
    color: var(--muted);
    font-style: italic;
    line-height: 1.5;
  }
  .body :global(p) {
    margin: 0 0 1rem;
    color: var(--muted);
    line-height: 1.7;
  }
  .body :global(strong) {
    color: var(--text);
    font-weight: 600;
  }
  .pager {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 2.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--line);
    flex-wrap: wrap;
  }
  .pager-link {
    color: var(--accent);
    font-weight: 600;
    font-size: 0.95rem;
  }
  .pager-link.next {
    margin-left: auto;
    text-align: right;
  }
</style>
